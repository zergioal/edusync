{
  "name": "edusync",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema de gestión de unidades educativas bolivianas",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:api": "pnpm --filter @edusync/api dev",
    "dev:web": "pnpm --filter @edusync/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "db:generate": "pnpm --filter @edusync/database db:generate",
    "db:push": "pnpm --filter @edusync/database db:push",
    "db:migrate": "pnpm --filter @edusync/database db:migrate",
    "db:seed": "pnpm --filter @edusync/database db:seed",
    "db:studio": "pnpm --filter @edusync/database db:studio",
    "test": "pnpm --filter @edusync/api test",
    "test:coverage": "pnpm --filter @edusync/api test:coverage",
    "postinstall": "find -L node_modules/.bin -maxdepth 1 -type f -exec chmod +x {} \\; 2>/dev/null || true"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
