# ════════════════════════════════════════════════════���══
# EduSync — Variables de entorno PRODUCCIÓN
# Copiar a .env y completar con valores reales
# NUNCA commitear este archivo con valores reales
# ═══════════════════════════════════════════════════════

# ─── Base de datos ──────────────────────────────────────────────────────────���─

# URL pooled para Prisma en runtime (pgBouncer, port 6543)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres"

# URL directa para migraciones (sin pgBouncer, port 5432)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# ─── Supabase Auth ────────────────────────────────────────────────────────────

SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
SUPABASE_JWT_SECRET="..."

# ─── Servidor API ─────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=4000

# Dominio base del sistema (sin protocolo)
BASE_DOMAIN="edusync.bo"

# Orígenes permitidos por CORS (separados por coma o regex de subdominio)
ALLOWED_ORIGINS="https://edusync.bo,https://app.edusync.bo"

# ─── Puppeteer (generación de PDFs en Railway) ───────────────────────────────

PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=false
PUPPETEER_EXECUTABLE_PATH="/usr/bin/chromium-browser"

# ─── Frontend (apps/web — Vercel) ─────────────────────────────────────────────

VITE_API_URL="https://api.edusync.bo/api/v1"
VITE_SUPABASE_URL="https://[project-ref].supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ..."
VITE_BASE_DOMAIN="edusync.bo"

# Tenant por defecto en desarrollo (ignorado en producción)
# VITE_DEV_TENANT=pioxii
