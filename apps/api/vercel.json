{
  "version": 2,
  "builds": [
    {
      "src": "dist/index.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": ["dist/**", "../../packages/database/node_modules/.prisma/**"]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "dist/index.js" }
  ]
}
