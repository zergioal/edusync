# ─── Base de datos (Supabase / PostgreSQL) ───────────────────────────────────

# URL de conexión pooled (para Prisma en runtime — usa pgBouncer)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# URL directa (para migraciones Prisma — sin pgBouncer)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── Supabase Auth ────────────────────────────────────────────────────────────

# URL del proyecto Supabase (ej: https://abcxyz.supabase.co)
SUPABASE_URL="https://[project-ref].supabase.co"

# Clave anon pública (safe para cliente)
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Clave service_role (SOLO backend — nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# JWT Secret del proyecto Supabase (Settings > API > JWT Secret)
# Usado por la API para verificar tokens de Supabase Auth
SUPABASE_JWT_SECRET="super-secret-jwt-token-with-at-least-32-characters-long"

# ─── API (apps/api) ───────────────────────────────────────────────────────────

PORT=4000
NODE_ENV=development

# Origen permitido por CORS (URL del frontend en desarrollo)
CORS_ORIGIN="http://localhost:5173"

# ─── Web (apps/web) ───────────────────────────────────────────────────────────

# URL base de la API (en desarrollo usa el proxy de Vite, en prod apunta directo)
VITE_API_URL="/api/v1"

# URL pública del proyecto Supabase (para el cliente JS de Supabase si se usa)
VITE_SUPABASE_URL="https://[project-ref].supabase.co"
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
